<%- include('./partials/header.ejs') %>

<main>
    <h1><%= title %></h1>

    <h2>Upcoming Service Projects</h2>

    <% const projectList = typeof projects !== 'undefined' ? projects : []; %>

    <% if (projectList.length > 0) { %>
        <ul>
            <% projectList.forEach(project => { %>
                <li>
                    <%= new Date(project.project_date).toLocaleDateString('en-US', {
                        year: 'numeric',
                        month: 'long',
                        day: 'numeric'
                    }) %>:
                    <%= project.title %>
                    (<%= project.organization_name %>)
                </li>
            <% }) %>
        </ul>
    <% } else { %>
        <p>No service projects are currently available.</p>
    <% } %>
</main>

<%- include('./partials/footer.ejs') %>