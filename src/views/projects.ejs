<%- include('./partials/header.ejs') %>

<main>

    <h1><%= title %></h1>

    <% if (user && user.role_name === 'admin') { %>

        <p>
            <a href="/new-project">
                Add a New Service Project
            </a>
        </p>

    <% } %>

    <h2>Upcoming Service Projects</h2>

    <% const projectList =
        typeof projects !== 'undefined'
            ? projects
            : [];
    %>

    <% if (projectList.length > 0) { %>

        <ul>

            <% projectList.forEach(project => { %>

                <li>

                    <a href="/project/<%= project.project_id %>">
                        <%= project.title %>
                    </a>

                    -

                    <a href="/organization/<%= project.organization_id %>">
                        <%= project.organization_name %>
                    </a>

                    -

                    <%= project.project_date %>

                    -

                    <%= project.location %>

                </li>

            <% }) %>

        </ul>

    <% } else { %>

        <p>
            No upcoming service projects are currently available.
        </p>

    <% } %>

</main>

<%- include('./partials/footer.ejs') %>