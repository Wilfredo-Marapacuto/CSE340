<%- include('./partials/header.ejs') %>

<main>

    <h1><%= title %></h1>

    <h2><%= projectDetails.title %></h2>

    <form
        action="/assign-categories/<%= projectId %>"
        method="POST"
    >

        <div>

            <% categories.forEach(category => { %>

                <div>

                    <input
                        type="checkbox"
                        id="category-<%= category.category_id %>"
                        name="categoryIds"
                        value="<%= category.category_id %>"
                        <%= assignedCategories.some(
                            assigned =>
                                assigned.category_id === category.category_id
                        )
                            ? 'checked'
                            : '' %>
                    >

                    <label
                        for="category-<%= category.category_id %>"
                    >
                        <%= category.name %>
                    </label>

                </div>

            <% }) %>

        </div>

        <button type="submit">
            Update Categories
        </button>

    </form>

</main>

<%- include('./partials/footer.ejs') %>