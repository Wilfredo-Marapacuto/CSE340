<%- include('./partials/header.ejs') %>

<main>

    <h1><%= title %></h1>

    <form
        action="/edit-category/<%= category.category_id %>"
        method="POST"
    >

        <div>

            <label for="name">
                Category Name
            </label>

            <input
                type="text"
                id="name"
                name="name"
                value="<%= category.name %>"
                maxlength="100"
                required
            >

        </div>

        <button type="submit">
            Update Category
        </button>

    </form>

</main>

<%- include('./partials/footer.ejs') %>
