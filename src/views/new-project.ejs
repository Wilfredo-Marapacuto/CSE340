<%- include('./partials/header.ejs') %>

<main>

    <h1><%= title %></h1>

    <form
        action="/new-project"
        method="POST"
    >

        <div>

            <label for="title">
                Project Title
            </label>

            <input
                type="text"
                id="title"
                name="title"
                maxlength="200"
                required
            >

        </div>

        <div>

            <label for="description">
                Description
            </label>

            <textarea
                id="description"
                name="description"
                maxlength="1000"
                required
            ></textarea>

        </div>

        <div>

            <label for="location">
                Location
            </label>

            <input
                type="text"
                id="location"
                name="location"
                maxlength="200"
                required
            >

        </div>

        <div>

            <label for="date">
                Date
            </label>

            <input
                type="date"
                id="date"
                name="date"
                required
            >

        </div>

        <div>

            <label for="organizationId">
                Organization
            </label>

            <select
                id="organizationId"
                name="organizationId"
                required
            >

                <option value="">
                    Select an organization
                </option>

                <% organizations.forEach(org => { %>

                    <option
                        value="<%= org.organization_id %>"
                    >
                        <%= org.name %>
                    </option>

                <% }) %>

            </select>

        </div>

        <button type="submit">
            Create Project
        </button>

    </form>

</main>

<%- include('./partials/footer.ejs') %>