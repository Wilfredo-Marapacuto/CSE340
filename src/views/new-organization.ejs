<%- include('partials/header') %>

<main>

    <h1><%= title %></h1>

    <form
        action="/new-organization"
        method="POST"
    >

        <div>

            <label for="name">
                Organization Name
            </label>

            <input
                type="text"
                id="name"
                name="name"
                required
            >

        </div>

        <div>

            <label for="description">
                Description
            </label>

            <textarea
                id="description"
                name="description"
                required
            ></textarea>

        </div>

        <div>

            <label for="contactEmail">
                Contact Email
            </label>

            <input
                type="text"
                id="contactEmail"
                name="contactEmail"
                required
            >

        </div>

        <button type="submit">
            Create Organization
        </button>

    </form>

</main>

<%- include('partials/footer') %>