<%- include('./partials/header.ejs') %>

<main>

    <h1><%= title %></h1>

    <h2><%= project.title %></h2>

    <p>
        <strong>Description:</strong>
        <%= project.description %>
    </p>

    <p>
        <strong>Date:</strong>
        <%= project.project_date %>
    </p>

    <p>
        <strong>Location:</strong>
        <%= project.location %>
    </p>

    <p>
        <strong>Organization:</strong>

        <a href="/organization/<%= project.organization_id %>">
            <%= project.organization_name %>
        </a>
    </p>

    <p>
        <a href="/assign-categories/<%= project.project_id %>">
            Edit Categories
        </a>
    </p>

    <h3>Categories</h3>

    <% const categoryList =
        typeof categories !== 'undefined'
            ? categories
            : [];
    %>

    <% if (categoryList.length > 0) { %>

        <ul>

            <% categoryList.forEach(category => { %>

                <li>

                    <a href="/category/<%= category.category_id %>">
                        <%= category.name %>
                    </a>

                </li>

            <% }) %>

        </ul>

    <% } else { %>

        <p>No categories available for this project.</p>

    <% } %>

</main>

<%- include('./partials/footer.ejs') %>