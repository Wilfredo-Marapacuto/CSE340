<%- include('./partials/header.ejs') %>

<main>

    <h1><%= title %></h1>

    <h2><%= category.name %></h2>

    <% if (user && user.role_name === 'admin') { %>

        <p>
            <a href="/edit-category/<%= category.category_id %>">
                Edit Category
            </a>
        </p>

    <% } %>

    <h3>Projects in this Category</h3>

    <% const projectList =
        typeof projects !== 'undefined'
            ? projects
            : [];
    %>

    <% if (projectList.length > 0) { %>

        <ul>

            <% projectList.forEach(project => { %>

                <li>

                    <a href="/project/<%= project.project_id %>">
                        <%= project.title %>
                    </a>

                </li>

            <% }) %>

        </ul>

    <% } else { %>

        <p>No projects are currently assigned to this category.</p>

    <% } %>

</main>

<%- include('./partials/footer.ejs') %>