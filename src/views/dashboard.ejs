<%- include('./partials/header.ejs') %>

<main>

    <h1><%= title %></h1>

    <h2>Dashboard</h2>

    <p>
        Name: <%= name %>
    </p>

    <p>
        Email: <%= email %>
    </p>

    <% if (user && user.role_name === 'admin') { %>

        <p>
            <a href="/users">
                View Registered Users
            </a>
        </p>

    <% } %>

    <h2>My Volunteer Projects</h2>

    <% if (
        volunteerProjects &&
        volunteerProjects.length > 0
    ) { %>

        <ul>

            <% volunteerProjects.forEach(project => { %>

                <li>

                    <strong>
                        <a href="/project/<%= project.project_id %>">
                            <%= project.title %>
                        </a>
                    </strong>

                    <br>

                    <%= project.organization_name %>

                    <br>

                    <%= project.location %>

                    <br>

                    <%= project.project_date %>

                    <form
                        action="/project/<%= project.project_id %>/remove-volunteer?redirect=dashboard"
                        method="POST"
                    >

                        <button type="submit">
                            Remove Volunteer Signup
                        </button>

                    </form>

                </li>

                <br>

            <% }) %>

        </ul>

    <% } else { %>

        <p>
            You have not volunteered for any projects yet.
        </p>

    <% } %>

</main>

<%- include('./partials/footer.ejs') %>